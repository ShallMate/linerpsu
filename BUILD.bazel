    ],
    linkopts = [
        "-no-pie",
        "-Wl,--allow-multiple-definition",
        "-fopenmp",
        "-L/usr/local/lib",
        "-Wl,--start-group",
        "-llibOTe",
        "-lSimplestOT",
        "-lKyberOT",
        "-lbitpolymul",
        "-lrelic_s",
        "-lcryptoTools",
        "-lmacoro",
        "-lcoproto",
        "-Wl,--end-group",
        "-lntl",
        "-lgmp",
        "-lssl",
        "-lcrypto",
        "-lsodium",
        "-ldl",
        "-lpthread",
    ],
)
